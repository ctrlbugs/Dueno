{
  "name": "Dueno Property Frontend Theme",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env ./node_modules/vite/bin/vite.js",
    "test:contact-email": "node --env-file=.env scripts/test-contact-email.mjs",
    "og:image": "node scripts/generate-og-image.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "build": "node scripts/generate-og-image.mjs && node scripts/generate-sitemap.mjs && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node --env-file=.env server/production.mjs",
    "start:prod": "npm run build && node --env-file=.env server/production.mjs",
    "db:up": "docker compose up -d",
    "db:schema": "docker compose exec postgres psql -U dueno -d dueno -f /schema/001_initial.sql"
  },
